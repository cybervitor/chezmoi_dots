# Setup base workspaces and execute apps at launch:

{{- if .is_laptop }}
workspace = 1, name:base, monitor:desc:HP Inc. HP E27 G5 CNC43529GK, default:true
exec-once = [workspace 1 silent] /usr/bin/betterbird

workspace = 2, name:browser, monitor:desc:HP Inc. HP E27 G5 CNC43529GS, default:true
exec-once = [workspace 2 silent] zen-browser

workspace = 3, name:coding, monitor:desc:HP Inc. HP E27 G5 CNC43529GS
exec-once = [workspace 3 silent] /usr/bin/codium

workspace = 9, name:logs, monitor:desc:HP Inc. HP E27 G5 CNC4352B36, default:true
exec-once = [workspace 9 silent] kitty
{{- else }}
workspace = 1, name:base, monitor:desc:LG Electronics LG ULTRAGEAR 509NTDVM2162, default:true
exec-once = [workspace 1 silent] zen-browser
{{- end }}

exec-once = [workspace special:magic silent] ferdium
