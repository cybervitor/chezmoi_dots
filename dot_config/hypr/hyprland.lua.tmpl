--#region ---- MY PROGRAMS ----

local terminal          = "kitty"
local fileManager       = "thunar"
local menu              = "killall fuzzel || fuzzel --use-bold --show-actions -R"
local bar               = "waybar"
local wallpaperManager  = "hyprpaper"
--#endregion

--#region ---- AUTOSTART ----

-- See https://wiki.hypr.land/Configuring/Basics/Autostart/
-- Autostart necessary processes (like notifications daemons, status bars, etc.)
hl.on("hyprland.start", function ()
	-- Daemons	
    hl.exec_cmd(wallpaperManager)
    hl.exec_cmd(bar)
    hl.exec_cmd("nm-applet")
    hl.exec_cmd("xsettingsd")
    hl.exec_cmd("blueman-applet")
    hl.exec_cmd("udiskie -t")
    hl.exec_cmd("eww daemon")
    hl.exec_cmd("systemctl --user start hyprpolkitagent")
    {{- if .is_laptop }}
    hl.exec_cmd("solaar -w hide")
--need to fix syntax    hl.exec_cmd("kanshi")
    {{- end }}

	-- startup programs  bound to workspaces
    hl.exec_cmd("/usr/bin/betterbird", {workspace = "1 silent"})
    hl.exec_cmd("zen-browser", {workspace = "2 silent"})
    hl.exec_cmd("kitty", {workspace = "8 silent"})
    hl.exec_cmd("ferdium", {workspace = "special:magic silent"})
end)
--#endregion

--#region ---- ENVIRONMENT VARIABLES ----

-- See https://wiki.hypr.land/Configuring/Advanced-and-Cool/Environment-variables/

--- Graphics Drivers ---
hl.env("__GLX_VENDOR_LIBRARY_NAME", "mesa")
