# Personal Aliases

# Alter default behaviour
alias ls='ls --color=auto'
alias grep='grep --color=auto'
alias ll="eza -Gloha --no-permissions --color=always --color-scale=all --color-scale-mode=gradient --hyperlink --absolute=off"
alias cat="bat"
alias find='fd'
alias du="dust"
alias free="duf"
alias nano="micro"
alias top="btop"

# Shortcuts
alias s="kitten ssh"
alias cz="chezmoi cd"
alias tss="clear && echo '\n\n' && fastfetch && echo '\n\n' && kitty +kitten icat ~/Pictures/Wallpapers/gundam-pixel-arts.gif"
alias ff='fastfetch'

# Quick editing
alias edit-alias='chezmoi edit $ZDOTDIR/my_alias && chezmoi apply'
alias edit-work-alias='chezmoi edit $ZDOTDIR/work_alias && chezmoi apply'
alias edit-zshrc='chezmoi edit $ZDOTDIR/.zshrc && chezmoi apply'
alias edit-zenv='chezmoi edit $ZDOTDIR/.zshenv && chezmoi apply'
alias edit-keybinds-zterminal='chezmoi edit $ZDOTDIR/keybinds && chezmoi apply'
alias edit-hypr-base="chezmoi edit $HYPRDIR/hyprland.lua && chezmoi apply"

# Aider - Gemini is balanced, Llamma is fastest, Qwen is fast but better, GPT has very little tokens
alias aid="aider --model gemini/gemini-2.5-flash"
alias aid-ffast="aider --model groq/llama-3.3-70b-versatile"
alias aid-fast="aider --model groq/qwen/qwen3-32b"
alias aid-smart="aider --model mistral/mistral-large-2512"
alias aid-snipe="OPENAI_API_BASE=https://models.inference.ai.azure.com OPENAI_API_KEY=$GITHUB_TOKEN aider --model openai/gpt-4o"
