# Personal Aliases

# Alter default behaviour
alias ls='ls --color=auto'
alias grep='grep --color=auto'
alias ll="eza -Gloha --no-permissions --color=always --color-scale=all --color-scale-mode=gradient --hyperlink --absolute=off"
alias cat="bat"
alias find='fd'
alias du="dust"
alias free="duf"
alias nano="micro"
alias top="btop"

# Shortcuts
alias s="kitten ssh"
alias cz="chezmoi cd"

# Quick editing
alias edit-alias='chezmoi edit $ZDOTDIR/my_alias && chezmoi apply'
alias edit-work-alias='chezmoi edit $ZDOTDIR/work_alias && chezmoi apply'

alias edit-zshrc='chezmoi edit $ZDOTDIR/.zshrc && chezmoi apply'
alias edit-zenv='chezmoi edit $ZDOTDIR/.zshenv && chezmoi apply'
alias edit-term-kbnds='chezmoi edit $ZDOTDIR/keybinds && chezmoi apply'

alias edit-hypr-base="chezmoi edit $HYPRDIR/hyprland.conf && chezmoi apply"
alias edit-hypr-monitors="chezmoi edit $HYPRDIR/monitors.conf && chezmoi apply"
alias edit-hypr-autostart="chezmoi edit $HYPRDIR/autostart.conf && chezmoi apply"
alias edit-hypr-workspaces="chezmoi edit $HYPRDIR/workspaces.conf && chezmoi apply"
alias edit-hypr-env_vars="chezmoi edit $HYPRDIR/env_vars.conf && chezmoi apply"
alias edit-hypr-permissions="chezmoi edit $HYPRDIR/permissions.conf && chezmoi apply"
alias edit-hypr-look_feel="chezmoi edit $HYPRDIR/look_feel.conf && chezmoi apply"
alias edit-hypr-input="chezmoi edit $HYPRDIR/input.conf && chezmoi apply"
alias edit-hypr-keybinds="chezmoi edit $HYPRDIR/keybinds.conf && chezmoi apply"
alias edit-hypr-windows_workspaces="chezmoi edit $HYPRDIR/windows_workspaces.conf && chezmoi apply"

# Aider - Gemini is balanced, Llamma is fastest, Qwen is fast but better, GPT has very little tokens
alias aid="aider --model gemini/gemini-2.5-flash"
alias aid-ffast="aider --model groq/llama-3.3-70b-versatile"
alias aid-fast="aider --model groq/qwen/qwen3-32b"
alias aid-smart="aider --model mistral/mistral-large-2512"
alias aid-snipe="OPENAI_API_BASE=https://models.inference.ai.azure.com OPENAI_API_KEY=$GITHUB_TOKEN aider --model openai/gpt-4o"
