# My personal functions

notebook() {
    local notesArray=("notes.md" "Work/work_notes.md" "Certification/certification_notes.md" "Personal/personal_notes.md")
	local toRun="$HOME/Documents/"

	if [[ $# -eq 0 ]]; then
        micro $toRun"${notesArray[1]}"
        return 0
    fi

    case "$1" in
        "work")
            toRun+="${notesArray[2]}"
            ;;
        "cert")
            toRun+="${notesArray[3]}"
            ;;
        "personal")
            toRun+="${notesArray[4]}"
            ;;
        *)
            echo "Invalid option: $1, choose a valid one (work | cert | personal) or leave empty for general notes"
            return 1
            ;;
    esac
    
    micro "$toRun"
    return 0
}
alias notes=notebook

silent-update-grub() {
    echo "Generating GRUB configuration at /boot/grub/grub.cfg ..."
    sudo grub-mkconfig -o /boot/grub/grub.cfg
    
    echo "=> Silencing GRUB output..."	# Deletes any line that contains 'echo Loading*'
    sudo sed -i -E '/^[[:space:]]*echo[[:space:]]+'\''Loading /d' /boot/grub/grub.cfg
    
    echo "=> Done! Silent boot maintained."
}
alias silent-grub=silent-update-grub
