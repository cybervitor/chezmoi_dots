# --- Auto-start Hyprland ---
# Only run if we are on a pure TTY1 and a Display Server isn't already running
if [[ -z $DISPLAY && $(tty) == /dev/tty1 ]]; then
    # We use 'exec' to replace the ZSH shell process with your bash script.
    # This ensures no extra shell processes are left running in the background!
    exec /home/cybervitor/.config/hypr/launch_hyprland.sh > /dev/null 2>&1
fi
