export HISTSIZE=100000      # Lines kept in interactive memory
export SAVEHIST=100000      # Lines saved to the file

setopt APPEND_HISTORY      # Append to the history file, don't overwrite it
setopt SHARE_HISTORY       # Share history across terminals immediately
setopt HIST_IGNORE_DUPS    # Don't record an entry that was just recorded again
setopt HIST_EXPIRE_DUPS_FIRST
setopt HIST_FIND_NO_DUPS
setopt HIST_REDUCE_BLANKS  # Remove superfluous blanks before recording entry
setopt HIST_VERIFY         # Don't execute immediately upon history expansion
setopt INC_APPEND_HISTORY  # Write to the history file immediately, not when shell exits

setopt AUTOCD
setopt NOBEEP
setopt NUMERIC_GLOB_SORT
